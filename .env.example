GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-now
GRAFANA_ROOT_URL=http://localhost:8080/grafana/
PROXY_BIND_ADDRESS=127.0.0.1
PROXY_PORT=8080
# HEC is not published on the host; it is reached via the proxy at
# /services/collector. This only sets the in-container listener port.
SPLUNK_HEC_PORT=8088
SPLUNK_PASSWORD=change-me-now
SPLUNK_HEC_TOKEN=change-me-now
SPLUNK_GENERAL_TERMS=--accept-sgt-current-at-splunk-com
